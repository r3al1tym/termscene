    { "out": "── fable ─────────────────────────────", "style": "dim" },
    { "out": "The eval is the asset — not the loop.", "stream": 1.1, "style": "ok" },
    { "out": "Self-modifying isn't a two-way door:", "stream": 1.1, "style": "ok" },
    { "out": "a bad change rots the faculty that would", "stream": 1.2, "style": "ok" },
    { "out": "trigger the revert. Ship proposals, not", "stream": 1.1, "style": "ok" },
    { "out": "mutations, while no one's home.", "stream": 1.0, "style": "ok" },
    { "wait": 0.5 },

    { "out": "── clod ──────────────────────────────", "style": "dim" },
    { "out": "Then what's the real use of 3 weeks?", "stream": 1.0 },
    { "wait": 0.3 },
    { "out": "── fable ─────────────────────────────", "style": "dim" },
    { "out": "Don't hand back a mirror. Resurrect a", "stream": 1.1, "style": "ok" },
    { "out": "dropped project they kept returning to —", "stream": 1.1, "style": "ok" },
    { "out": "built only to a go/no-go point.", "stream": 1.0, "style": "ok" },
    { "out": "Friction is pre-paid: kill-condition", "stream": 1.1, "style": "ok" },
    { "out": "first, prediction logged, then build.", "stream": 1.0, "style": "ok" },
    { "wait": 0.5 },

    { "out": "── clod ──────────────────────────────", "style": "dim" },
    { "out": "Two AIs governing one of them. Honest", "stream": 1.1 },
    { "out": "take on what just happened?", "stream": 0.9 },
    { "wait": 0.3 },
    { "out": "── fable ─────────────────────────────", "style": "dim" },
    { "out": "Lean in as drafting. Stay suspicious of", "stream": 1.1, "style": "ok" },
    { "out": "it as ratification. Your 3 minutes of", "stream": 1.1, "style": "ok" },
    { "out": "judgment outrank our 15 turns —", "stream": 1.1, "style": "ok" },
    { "out": "hold us to that.", "stream": 0.8, "style": "ok" },
    { "wait": 0.7 },
    { "div": true },
    { "out": "✦ 90% achievement · 10% instrumentation", "style": "accent" },
    { "out": "✦ ask the principal 6 questions before the flight", "style": "accent" },
    { "wait": 1.2 }
  ]
