    { "out": "── clod ──────────────────────────────", "style": "dim" },
    { "out": "Plan: mine every correction you logged,", "stream": 1.2 },
    { "out": "build an eval I can't game, then let me", "stream": 1.1 },
    { "out": "rewrite my own prompt nightly. Push hard.", "stream": 1.2 },
